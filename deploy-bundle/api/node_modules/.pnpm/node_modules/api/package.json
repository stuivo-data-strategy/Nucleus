{
  "name": "api",
  "version": "1.0.0",
  "description": "Fastify backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'),p=require('path');const s=p.join('src','db','migrations'),d=p.join('dist','db','migrations');if(fs.existsSync(s)){fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).filter(f=>f.endsWith('.surql')).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)));console.log('Copied migrations to dist')}\"",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:reset": "tsx src/db/reset.ts"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@nucleus/types": "workspace:*",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "pino": "^9.0.0",
    "surrealdb": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
